FLASK_ENV=production
PORT=5000
CLIENT_ORIGIN=https://your-all-tourism-assistant.vercel.app,http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET_KEY=replace-with-long-random-secret-at-least-32-characters
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/all_tourism_assistant?retryWrites=true&w=majority
MONGO_DB_NAME=all_tourism_assistant
OPENAI_API_KEY=replace-with-openai-key
OPENAI_MODEL=gpt-4o-mini
GOOGLE_MAPS_API_KEY=replace-with-google-maps-key
